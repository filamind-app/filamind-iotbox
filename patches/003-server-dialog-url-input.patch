From: filamind <abdelmonemawad@hotmail.com>
Subject: [PATCH 3/4] iot_drivers: add direct URL entry tab to ServerDialog

Replaces the single "Server token" field with a tabbed dialog offering
two equivalent paths:
  * "Server URL"     — paste a bare https URL (filamind extension)
  * "Pairing Token"  — paste the full token from the IoT app (upstream)

The submit button calls `/iot_drivers/connect_to_server` with either
`{url: ...}` or `{token: ...}` depending on the active tab.

---
 .../static/src/app/components/dialog/ServerDialog.js | 92 ++++++++++++++++----
 1 file changed, 76 insertions(+), 16 deletions(-)

diff --git a/addons/iot_drivers/static/src/app/components/dialog/ServerDialog.js b/addons/iot_drivers/static/src/app/components/dialog/ServerDialog.js
--- a/addons/iot_drivers/static/src/app/components/dialog/ServerDialog.js
+++ b/addons/iot_drivers/static/src/app/components/dialog/ServerDialog.js
@@ -12,17 +12,21 @@ export class ServerDialog extends Component {

     setup() {
         this.store = useStore();
-        this.state = useState({ waitRestart: false, loading: false, error: null });
-        this.form = useState({ token: "" });
+        this.state = useState({ waitRestart: false, loading: false, error: null, mode: "url" });
+        this.form = useState({ token: "", url: "" });
     }

     async connectToServer() {
         this.state.loading = true;
         this.state.error = null;
+        const params = this.state.mode === "url"
+            ? { url: this.form.url }
+            : { token: this.form.token };
         try {
             const data = await this.store.rpc({
                 url: "/iot_drivers/connect_to_server",
                 method: "POST",
-                params: this.form,
+                params,
             });

             if (data.status === "success") {
