From: filamind <abdelmonemawad@hotmail.com>
Subject: [PATCH 2/4] iot_drivers: extend connect_to_server with URL + pairing code

Adds two optional keyword arguments to /iot_drivers/connect_to_server:
  * url=None   -- self-hosted Odoo server URL
  * code=None  -- 8-char pairing code generated by the filamind-iot addon
                  (https://github.com/filamind-app/filamind-iot)

Behavior matrix:
  url + code      -> POST {url}/filamind_iot/pair with this box's identifier;
                     the addon issues a permanent token and we save it.
  url   only      -> store the URL, leave token blank; pair later from the
                     Odoo side using box-token mode in the wizard.
  token only      -> existing upstream token-string flow, untouched.

The original signature `def connect_to_odoo_server(self, token)` is preserved
positionally; both new parameters default to None so existing callers (if any)
continue to work.

---
 addons/iot_drivers/controllers/homepage.py | 32 ++++++++++++++++++++++++++++-
 1 file changed, 31 insertions(+), 1 deletion(-)

diff --git a/addons/iot_drivers/controllers/homepage.py b/addons/iot_drivers/controllers/homepage.py
--- a/addons/iot_drivers/controllers/homepage.py
+++ b/addons/iot_drivers/controllers/homepage.py
@@ -288,7 +288,39 @@ class IotBoxOwlHomePage(http.Controller):
         return {'status': 'success' if system.toggle_remote_debug() else 'failure'}

     @route.iot_route('/iot_drivers/connect_to_server', type="jsonrpc", methods=['POST'], cors='*')
-    def connect_to_odoo_server(self, token):
+    def connect_to_odoo_server(self, token=None, url=None, code=None):
+        # filamind: URL + pairing code -> round-trip to {url}/filamind_iot/pair
+        # to obtain a permanent token bound to this box's IOT_IDENTIFIER.
+        if url and code:
+            import requests
+            import socket
+            pair_url = url.rstrip('/') + '/filamind_iot/pair'
+            payload = {
+                'code': code.strip().upper(),
+                'identifier': system.IOT_IDENTIFIER,
+                'ip_address': system.get_ip(),
+                'mac_address': system.get_mac_address(),
+                'hostname': socket.gethostname(),
+                'version': system.get_version(),
+            }
+            try:
+                resp = requests.post(pair_url, json=payload, timeout=10, verify=False)
+                data = resp.json() if resp.content else {}
+            except (requests.RequestException, ValueError):
+                return {'status': 'failure', 'message': 'Could not reach pairing endpoint.'}
+            if resp.status_code != 200 or 'token' not in data:
+                return {'status': 'failure', 'message': data.get('error') or 'Pairing failed.'}
+            helpers.save_conf_server(url=url, token=data['token'])
+            helpers.odoo_restart(1)
+            return {'status': 'success', 'message': 'Paired with filamind server. IoT will restart.'}
+        # filamind: URL only -> direct save (legacy single-field behaviour)
+        if url and not token:
+            try:
+                helpers.save_conf_server(**helpers.parse_url(url))
+            except ValueError:
+                return {'status': 'failure', 'message': 'Invalid URL provided.'}
+            helpers.odoo_restart(1)
+            return {'status': 'success', 'message': 'Server URL saved. IoT will restart.'}
